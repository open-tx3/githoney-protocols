# GitHoney Badges — Preprod profile
#
# Preprod deployment recovered from the githoney-io/worker config
# (https://github.com/githoney-io/worker). All values are public on-chain data.

# --- Published GitHoney settings UTxO (referenced by update_badge / collect_badge_utxos) ---
# config.json: validator_ref  (must match the githoney-setup / bounties deployment)
SETTINGS_REF=0x9edc3087527514724b297475f84a8ab316faab1950ce1882715cf4bf88b20b64#0

# --- Badge spend validator ---
# config.json: badges_script
BADGES_
BADGES_SCRIPT_VERSION=3

# --- Badge minting policy (same multi-purpose badge script; id = its hash) ---
BADGE_POLICY_
BADGE_POLICY_SCRIPT_VERSION=3
# script_badge address hash (= Hasher224 of badges_script)
BADGE_POLICY_ID=0xf2142e5b751cdb834ed75a5215f47759d0ddc37937b01a4cb97178c1

    }

    collateral {
        from: Admin,
        min_amount: Ada(5000000),
    }

    input funds {
        from: Admin,
        min_amount: min_utxo(change) + min_utxo(reward) + min_utxo(refund) + fees,
    }

    input bounty {
        ref: bounty_ref,
        datum_is: BountyDatum,
        redeemer: BountyRedeemer::Close {},
    }

    mint {
        amount: AnyAsset(bounty_policy_id, bounty_id, -1),
        redeemer: (),
    }

    output reward {
        to: Maintainer,
        amount: Ada(min_ada) + AnyAsset(reward_policy_id, reward_asset_name, reward_amount),
    }

    output deposit {
        to: Contributor,
        amount: Ada(min_ada),
    }

    output change {
        to: Admin,

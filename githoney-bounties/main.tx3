    output refund {
        to: Sponsor,
        amount: AnyAsset(refundings_policy_id, refundings_asset_name, refundings_amount) + min_utxo(refund),
    }

    validity {
        until_slot: until,
        since_slot: since,
    }

    signers {
        Admin,
    }

    metadata {
        674: "Githoney: Close assigned and sponsored bounty",
    }
}

/// Admin marks the bounty merged, takes the GitHoney reward-fee cut, and
/// returns the maintainer's min-ADA. After this the contributor can claim.
tx merge_bounty(
    /// The bounty UTxO being merged.
    bounty_ref: UtxoRef,
    /// Reward-token amount GitHoney takes as its fee.
    githoney_fee: Int,
    /// Min-UTxO lovelace returned to the maintainer.
    min_ada: Int,
    /// Asset name of the reward token the fee is taken from.
    reward_asset_name: Bytes,
    /// Policy id of the reward token the fee is taken from.
    reward_policy_id: Bytes,
    /// Script-fee amount (unused in the body; kept for ABI stability).
    script_fee: Int,
    /// Updated `initial_value` lovelace entry for the bounty datum.
    initial_funds: Int,
    /// Validity-window lower bound (slot).
    since: Int,
    /// Validity-window upper bound (slot).
    until: Int,
) {
    reference settings {
        ref: settings_ref,
        datum_is: SettingsDatum,
    }

    collateral {
        from: Admin,
        min_amount: Ada(5000000),
    }

    input funds {
        from: Admin,
        min_amount: min_utxo(fee) + fees + min_utxo(change),
    }

    input bounty {
        ref: bounty_ref,
        datum_is: BountyDatum,
        redeemer: BountyRedeemer::Merge {},
    }


    output updated_bounty {
        to: Vault,
        amount: bounty - AnyAsset(reward_policy_id, reward_asset_name, githoney_fee) - Ada(min_ada),
        datum: BountyDatum {
            admin_payment_credential: bounty.admin_payment_credential,
            maintainer_address: bounty.maintainer_address,
            contributor_address: bounty.contributor_address,
            bounty_reward_fee: bounty.bounty_reward_fee,
            deadline: bounty.deadline,
            merged: true,
            initial_value: {
                "": {
                    "": initial_funds,
                },
            },
        },
    }

    output fee {
        to: GitHoney,
        amount: AnyAsset(reward_policy_id, reward_asset_name, githoney_fee) + min_utxo(fee),
    }

    output deposit {
        to: Maintainer,
        amount: Ada(min_ada),
    }

    output change {
        to: Admin,
        // NOTE: admin pays the min ada to create the fee output (1168010 lovelace)
        amount: funds - fees - min_utxo(fee),
    }

    validity {
        until_slot: until,
        since_slot: since,
    }

    signers {
        Admin,
    }

    metadata {
        674: "Githoney: Merge bounty",
    }
}

/// Contributor claims the full reward from a merged bounty and burns the bounty NFT.
tx claim_bounty(
    /// Asset name of the bounty NFT to burn.
    bounty_id: Bytes,
    /// The bounty UTxO being claimed.
    bounty_ref: UtxoRef,
    /// Min-UTxO lovelace floor (unused in the body; kept for ABI stability).
    min_ada: Int,
    /// Validity-window lower bound (slot).
    since: Int,
    /// Validity-window upper bound (slot).
    until: Int,
) {
    reference settings {
        ref: settings_ref,
        datum_is: SettingsDatum,
    }

    collateral {
        from: Contributor,
        min_amount: Ada(5000000),
    }

    input funds {
        from: Contributor,
        min_amount: min_utxo(reward) + fees,
    }

    input bounty {
        ref: bounty_ref,
        datum_is: BountyDatum,
        redeemer: BountyRedeemer::Claim {},
    }

    mint {
        amount: AnyAsset(bounty_policy_id, bounty_id, -1),
        redeemer: (),
    }

    output reward {
        to: Contributor,
        amount: funds + bounty - AnyAsset(bounty_policy_id, bounty_id, 1) - fees,
    }

    validity {
        until_slot: until,
        since_slot: since,
    }

    metadata {
        674: "Githoney: claim bounty",
    }
}
